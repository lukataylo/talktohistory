# ── Backend secrets (apps/server, set on Railway) ────────────────────────────
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Flip integrations on/off independently so tracks can land one at a time.
# When false (default), the server returns deterministic MOCK data for that capability.
AI_STORY_PROVIDER=mock        # mock | gemini
AI_TTS_PROVIDER=mock          # mock | eleven
AI_STICKER_PROVIDER=mock      # mock | imgly | gemini
DB_PROVIDER=memory            # memory | postgres
DATABASE_URL=                 # required only when DB_PROVIDER=postgres

PORT=8787

# ── Frontend (apps/web, Vite) ────────────────────────────────────────────────
# Point the PWA at the API. Empty = same-origin (server serves the built PWA).
VITE_API_BASE=
# Run the whole frontend with in-browser mocks, zero backend needed.
VITE_MOCK=false

# ── Mobile (apps/mobile, Expo) ───────────────────────────────────────────────
# The deployed PWA URL the WebView shell loads.
EXPO_PUBLIC_WEBAPP_URL=http://localhost:5173
