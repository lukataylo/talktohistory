{
  "name": "@tth/db",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm --filter @tth/shared build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "pnpm --filter @tth/shared build",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tth/shared": "workspace:*"
  },
  "peerDependencies": {
    "pg": "*"
  },
  "peerDependenciesMeta": {
    "pg": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
