# NearPast Expo Go shell — environment

# The NearPast PWA URL the WebView loads.
#
# On a REAL PHONE running Expo Go, "localhost" is the phone itself — it will NOT
# reach your dev machine. Use one of:
#   - your machine's LAN IP + Vite port:  http://192.168.x.x:5173
#     (start the web app with: pnpm --filter @tth/web dev  — it binds 0.0.0.0)
#   - the deployed HTTPS URL:             https://your-nearpast.up.railway.app
#
# HTTPS is strongly preferred: browser geolocation/camera are most reliable
# over a secure origin.
EXPO_PUBLIC_WEBAPP_URL=http://192.168.1.42:5173
